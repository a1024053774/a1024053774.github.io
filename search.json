---
layout: null
---
[
  {% assign visible_posts = site.posts | where_exp: "post", "post.hidden != true" | sort: "last_modified_at_iso" | reverse %}
  {% for post in visible_posts %}
    {
      "title"    : "{{ post.title | escape }}",
      "subtitle" : "{{ post.subtitle | escape }}",
      "tags"     : "{{ post.tags | join: ', ' }}",
      "url"      : "{{ site.baseurl }}{{ post.url }}",
      "date"     : "{{ post.last_modified_at | date: '%Y-%m-%d' }}"
    } {% unless forloop.last %},{% endunless %}
  {% endfor %}
]
